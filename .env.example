# ─────────────────────────────────────────────────────────────
# The Linen Solutions — environment configuration
#
# LOCAL DEMO MODE (default):
#   Leave everything below blank/unset. The site runs on rich
#   built-in sample data saved to your browser. Perfect for demos.
#
# LIVE FIREBASE MODE:
#   Fill these in with values from your Firebase project
#   (Project settings → Your apps → SDK setup & configuration).
#   When VITE_FIREBASE_API_KEY is present the site automatically
#   switches to live Firestore + Storage + Auth.
# ─────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: restrict admin access to a single email (Firebase mode).
VITE_ADMIN_EMAIL=

# Local-demo admin password (only used when Firebase is NOT configured).
VITE_DEMO_ADMIN_PASSWORD=linen-admin

# Only set this if hosting at username.github.io/thelinensolutions/
# instead of a custom domain. Example: /thelinensolutions/
# VITE_BASE=/
