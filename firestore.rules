rules_version = '2';
// The Linen Solutions — Firestore security rules.
// Anyone can READ the catalogue (it's a public website); only a signed-in
// admin can WRITE. Paste this into Firebase console →
//   Build → Firestore Database → Rules → (replace all) → Publish.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
